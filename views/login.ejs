<div class="login-bg">
  <div class="login-card">
    <div class="login-badge">
      <span class="tc-badge tc-badge-lg">TC</span>
    </div>
    <h1 class="login-title">Transaction Command</h1>
    <div class="login-sub">Projects with a Purpose LLC</div>

    <% if (error) { %>
      <div class="login-error"><%= error %></div>
    <% } %>

    <form action="/login" method="POST" class="login-form">
      <label for="username">Username</label>
      <input type="text" name="username" id="username" autofocus autocomplete="username" required />

      <label for="password">Password</label>
      <input type="password" name="password" id="password" autocomplete="current-password" required />

      <button type="submit" class="btn btn-primary btn-block">Sign In</button>
    </form>

    <div class="login-meta">AI-Powered Transaction Compliance</div>
  </div>
</div>
